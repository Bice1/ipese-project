    "UNITS": {
        "Methanat": {
            "Unit Description": "MethanatorUtil is a Utility-type unit (Fmin=0, Fmax=10000, Cinv2='Cinv2_meth') that consumes compressed H2 (8 kg/h, hydrogen layer) and compressed CO2 (44 kg/h, Comp_CO2 layer), producing CH4 (kW LHV basis) and water (0.036 m³/h). It includes 3 exothermic hot heat streams for inter-stage cooling (q_meth1–3), with duties computed as specific heat [kWh/kgCH4] × CH4 mass flow.",
            "Unit Info": {
                "Unit name": "Methanat",
                "Minimum capacity multiplier": 0.0,
                "Maximum capacity multiplier": 100.0
            },
            "Connectors Description": "",
            "Connectors": [
                {
                    "NAME (ALIAS)": "hydrogen",
                    "TYPE": "MASS",
                    "DIRECTION": "IN",
